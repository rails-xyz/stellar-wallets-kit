else
  export NODE_PATH="/home/runner/work/stellar-wallets-kit/stellar-wallets-kit/src/dist/node_modules/.pnpm/@ethereumjs+rlp@10.1.1/node_modules/@ethereumjs/rlp/bin/node_modules:/home/runner/work/stellar-wallets-kit/stellar-wallets-kit/src/dist/node_modules/.pnpm/@ethereumjs+rlp@10.1.1/node_modules/@ethereumjs/rlp/node_modules:/home/runner/work/stellar-wallets-kit/stellar-wallets-kit/src/dist/node_modules/.pnpm/@ethereumjs+rlp@10.1.1/node_modules/@ethereumjs/node_modules:/home/runner/work/stellar-wallets-kit/stellar-wallets-kit/src/dist/node_modules/.pnpm/@ethereumjs+rlp@10.1.1/node_modules:/home/runner/work/stellar-wallets-kit/stellar-wallets-kit/src/dist/node_modules/.pnpm/node_modules:$NODE_PATH"
