  exec "$basedir/node"  "$basedir/../../../../../../@ethereumjs+rlp@10.1.1/node_modules/@ethereumjs/rlp/bin/rlp.cjs" "$@"
else
  exec node  "$basedir/../../../../../../@ethereumjs+rlp@10.1.1/node_modules/@ethereumjs/rlp/bin/rlp.cjs" "$@"
